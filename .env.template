# [Ref: 03_原子目标与规约/_共享规约/02_三位一体仓库规约] 占位，禁止填写真实 Key
# 复制为 .env 后本地填写，不要提交 .env
# Stage2 下游连接：与 diting-infra 部署的 L1/L2/Redis 对应；make verify diting prod 必验 L1、L2、Redis（含缓存/队列性能测试）

# ---------- 必填（拉代码后本地/联调必备）----------
# L1 TimescaleDB（OHLCV）；示例：postgresql://user:pass@host:port/dbname；本地 Compose 为 localhost:15432
TIMESCALE_DSN=

# L2 知识库 PostgreSQL；示例：postgresql://user:pass@host:5432/dbname；本地 Compose 为 localhost:15433；连远程库时填 公网IP:NodePort（可从 diting-infra 的 prod.conn 复制 PG_L2_DSN）
PG_L2_DSN=
# 首次连库若报 relation does not exist：在仓库根执行 make init-l2-b-module-tables（建 classifier / quant_signal / industry_revenue_summary 等）

# Redis（默认部署、必验）；示例：redis://:pass@host:6379/0；本地 Compose 为 redis://localhost:15479/0
REDIS_URL=

# ---------- 可选（按需填写）----------
API_KEY=
DB_URL=

# ---------- 信号层 AI（Segment 信号理解）[Ref: 06_B轨_信号层生产级数据采集] ----------
# 启用 AI 路径需在 config/signal_layer.yaml signal_understanding.model_id 填写模型名
# API Key：SIGNAL_LAYER_API_KEY 优先；未设则回退 OPENAI_API_KEY
# SIGNAL_LAYER_API_KEY=
# SIGNAL_LAYER_MODEL_ID=gpt-4
# SIGNAL_LAYER_BASE_URL=https://api.openai.com/v1
# 指定股票（默认一套，采集与 Module A/B 共用）：设为逗号分隔或文件路径则仅对这些标的采集/分类/扫描；未设置则全量
# DITING_SYMBOLS=000001.SZ,600000.SH
# 可选覆盖：仅采集用 INGEST_PRODUCTION_SYMBOLS，仅 A/B 用 MODULE_AB_SYMBOLS

# ---------- Module C（MoE）[Ref: 04_A轨_MoE议会_实践] ----------
# 生产约定：仅处理「确认档 ∪ 预警档」标的（MOE_C_SCOPE=snapshot，默认）；与 B 表 quant_signal_snapshot 一致；量化门控见 config/moe_router.yaml require_quant_passed
# 细分占位：脚本默认 MOE_STUB_SEGMENT_SIGNALS=0（走真实细分信号；须 segment_signal_cache 等）。联调或纯管道验证显式 MOE_STUB_SEGMENT_SIGNALS=1；make run-module-c 会传 1
# MOE_STUB_SEGMENT_SIGNALS=0
# MOE_ENABLE_VC_AGENT=1
# 轨标识：a=A 轨短线（默认）—信号层不跑细分、不写 segment_signal_cache，仅主分类+标的新闻条数观测；b=B 轨中线—全量细分 refresh→segment_signal_cache；b 时 C 与 refresh 从 b_track_candidate_snapshot 取 symbols，horizon=MEDIUM_TERM
# DITING_TRACK=a
# 信号层 refresh 标的范围：snapshot（默认）= 仅 B 模块通过/预警档；full = 全量 a_share_universe
# REFRESH_SEGMENT_SCOPE=snapshot
# 流水线：已配 PG_L2_DSN 且未设本项时，脚本默认 snapshot（从 L2 读 B，与 make run-module-b 只数一致，不重扫）
# 显式 full = 本机 QuantScanner 重算 B（与上次 B 终端可能不一致）；无 PG_L2 且未设本项时默认 full
# MOE_PIPELINE=full
# A 仅内存分类时须配置 TIMESCALE_DSN（L1），否则 B 扫描逐标的拉 K 线，大名单极慢；MOE_PIPELINE=snapshot 时不跑 B 扫描、可不配 TIMESCALE_DSN
# segment_list/tags：MOE_SEGMENT_SOURCE=classifier（默认）；=snapshot 时从 L2 classifier_output_snapshot 读（仍可与 full 组合，仅替换 A）
# MOE_SEGMENT_SOURCE=classifier
# 与 L2 快照对齐：限定 classifier_output_snapshot / quant_signal_scan_all 的 batch（可选；不设则 Module C 自动用 L2 最近一次整批写入）
# MOE_CLASSIFIER_BATCH_ID=
# MOE_QUANT_BATCH_ID=
# 与 B 对齐：默认仅对「写入 quant_signal_snapshot 供 C」的标的跑 MoE（confirmed_passed∨alert_passed）；全 universe 与 B 同口径时设 MOE_C_SCOPE=all；仅确认档设 MOE_C_SCOPE=passed
# MOE_C_SCOPE=snapshot
# Router：自定义领域标签 → 农业/科技/宏观 的映射在 config/moe_router.yaml（tag_to_router_domain、unmapped_router_domain），勿用环境变量硬编码
# 覆盖写入 moe_expert_opinion_snapshot 的 batch_id（默认用本次运行的 correlation / L2 推断 batch）
# MOE_OUTPUT_BATCH_ID=
# 终端明细：默认打印 scope 内全部标的；仅打印前 N 行时设 MOE_C_PRINT_ALL=0 与 MOE_C_PRINT_MAX（默认 20）
# MOE_C_PRINT_MAX=20
# MOE_C_PRINT_ALL=0
# 短轨摘要列：MOE_C_REASON_WIDTH=最小列宽（默认 12）；MOE_C_REASON_MAX=0 或未设=按本批最长摘要撑满不省略；正数=硬上限（超长省略）
# MOE_C_VERBOSE=0
# MOE_C_REASON_WIDTH=
# MOE_C_REASON_MAX=

# ---------- Module B 扫描门控（可选，覆盖 scanner_rules.yaml）[Ref: 03_量化扫描引擎_实践] ----------
# B 终端：确认档列表与执行标的清单默认全部打印；极大名单时可限制行数（0 或不设为不限制）
# MODULE_B_PRINT_MAX=
# B→C：L2 表 quant_signal_snapshot（确认∪预警）+ quant_signal_scan_all（全量）；C 对齐本批 B 请设 MOE_QUANT_BATCH_ID=<B 终端 batch_id>
# SCANNER_CLASSIFIER_BATCH_ID=
# scripts/run_daily_scan.py 末尾可选跑 C：RUN_MODULE_C=1
# run_full_pipeline（make run-full-pipeline 全系统全链路）：RUN_MODULE_A=1 RUN_REFRESH_AFTER_B=1 RUN_MODULE_C=1（默认全开）
# 全链路默认精简逐条明细，但保留每步「下一模块依赖」交接（batch、L1、门控等）；完整日志 export PIPELINE_VERBOSE=1；L2 汇总 make query-full-pipeline-result
# PIPELINE_VERBOSE=
# PIPELINE_QUIET=
# 全链路人眼校准：有/无细分信号等列表默认打印条数上限（run_full_pipeline 默认 32）
# PIPELINE_CALIBRATION_LIST_MAX=32
# 信号层 refresh 工作结果表：news_content 回溯天数、主营分部营收占比下限、最大输出行数
# REFRESH_SEGMENT_DAYS_BACK=7
# PIPELINE_SEGMENT_REVENUE_FLOOR=0.3
# PIPELINE_SEGMENT_TABLE_MAX=80
# 信号层工作结果块：摘要换行宽度（64–132，默认 88）
# PIPELINE_SEGMENT_REPORT_WIDTH=88

# ---------- 采集加速与限速（make ingest-production / make ingest-production-incremental）----------
# [Ref: 04_阶段规划与实践/Stage2_数据采集与存储/06_生产级数据要求_实践.md]
# OHLCV 数据源：akshare（默认）、baostock 或 jqdata。也可用 INGEST_SOURCE=jqdata 统一走 JQData
# INGEST_OHLCV_SOURCE=akshare
# 全 A 股 OHLCV 并发数（默认 1 串行，减轻断连）；可试 2～3 加速，断连则改回 1
# 云服务器跑 AkShare/东方财富 易 RemoteDisconnected 时，可适当减小批次、加大间隔（按需取消注释）：
# requests 默认超时（秒），含 akshare 与上交所 query.sse.com.cn 等大响应；弱网建议 ≥90，最大 300
INGEST_REQUESTS_TIMEOUT=90
INGEST_OHLCV_BATCH_SIZE=150
INGEST_OHLCV_BATCH_PAUSE_SEC=5
INGEST_OHLCV_DELAY_BETWEEN_SYMBOLS=5

# ---------- 生产采集开关与时间线（make ingest-production，符合 AB 模块生产要求）----------
# 开关：true/false（或 1/0）。时间范围由下方 DAYS_BACK 单独配置。
# 标的池（全 A 股列表，写入 a_share_universe）
INGEST_PRODUCTION_UNIVERSE=true
# K 线/量化（OHLCV 写入 L1，Module B 用）
INGEST_PRODUCTION_OHLCV=true
# 行业/财务（财务摘要写入 L2，Module A 用）
INGEST_PRODUCTION_INDUSTRY_REVENUE=true
# 主营构成（东方财富 stock_zygc_em → L2 segment_registry / symbol_business_profile，Module A 真实 segment_shares）
INGEST_PRODUCTION_BUSINESS_PROFILE=true
# INGEST_BUSINESS_REFRESH_DAYS=120
# make ingest-business-profile 批采：相邻标的间隔（秒）、AkShare 请求 socket 超时（秒，防卡死）
# INGEST_BUSINESS_BATCH_PAUSE_SEC=0.35
# INGEST_AKSHARE_SOCKET_TIMEOUT_SEC=120
# 新闻（全市场 + 按标个股新闻写入 L2 news_content，Module C 用）
# 存量库须执行一次：make migrate-l2-news-content-scope（news_content 增加 scope/scope_id，见 07_ 设计）
# A 轨双路打标表：make init-l2-a-track-signal-cache
INGEST_PRODUCTION_NEWS=true
# 新闻：false=已有最新新闻则跳过（默认）；true=每次都全量拉。最新=该标的最近新闻在 INGEST_NEWS_STALE_DAYS 天内
# INGEST_NEWS_ALWAYS_REFRESH=false
# 新闻「已有最新」判定：最近一条在 N 天内则跳过，默认 1
# INGEST_NEWS_STALE_DAYS=1
# 新闻拉取并行数：1=串行；>1 时本批多标的同时请求远程，拉取后与 DB 比较，无新数据则不写
# INGEST_NEWS_PARALLEL=5
# 采集 ①.5 是否自动从远程拉中文名写入 L2 symbol_names：true / false（或 1 / 0），默认 true
# 设为 false 时在本地维护 config/symbol_names.csv 后执行：make sync-symbol-names-csv
INGEST_SYMBOL_NAMES=true
# 中文名数据源：eastmoney=东方财富个股接口（默认，与 K 线同源）；akshare_bulk=沪深全表（大响应易断连）
# INGEST_SYMBOL_NAMES_MODE=eastmoney
# 个股接口逐只请求间隔（秒），降限流概率
# INGEST_SYMBOL_NAME_PAUSE_SEC=0.2
# 指定股票采集：优先用 DITING_SYMBOLS（与 A/B 共用）；未设置则按 universe 全量。逗号分隔或文件路径
# INGEST_PRODUCTION_SYMBOLS=000001.SZ,600000.SH
# 时间范围（仅当未配置下方 INGEST_JQDATA_DATE_* 时生效）：K 线回溯天数、新闻保留最近 N 天
INGEST_PRODUCTION_OHLCV_DAYS_BACK=1825
INGEST_PRODUCTION_NEWS_DAYS_BACK=365
# 行业/财务/新闻「同时拉几只」：1=一只一只拉，3=同时拉 3 只（再下一组）。设大易触发限流。
# INGEST_PRODUCTION_CONCURRENT_STEPS=3
# K 线全量每子批最多多少只（0=不切分）。例如 50 表示 150 只分 3 次拉，减轻单次压力。
# INGEST_OHLCV_BATCH_CHUNK_SIZE=50
# ---------- 数据源：JQData（聚宽）----------
# 使用 JQData 时设 INGEST_SOURCE=jqdata，标的/行情/行业财务均从聚宽拉取；需聚宽账号并 pip install jqdatasdk
INGEST_SOURCE=jqdata
JQDATA_USER=13031539952
JQDATA_PASSWORD=Hui123123
# 统一拉取时间范围（格式 YYYY-MM-DD）：与 INGEST_SOURCE 无关，akshare/jqdata 均按此区间拉 K 线/新闻；未配置时用 DAYS_BACK
INGEST_JQDATA_DATE_START=2025-05-01
INGEST_JQDATA_DATE_END=2025-12-01
