# 生产环境连接信息（自动生成；勿提交 Git）
# 来源: make deploy diting prod @ diting-infra
TIMESCALE_DSN=postgresql://postgres:postgres@43.99.72.154:30001/postgres
PG_L2_DSN=postgresql://postgres:postgres@43.99.72.154:30002/diting_l2
REDIS_URL=redis://43.99.72.154:30379/0
KUBECONFIG=/root/.kube/config-diting-prod
PUBLIC_IP=43.99.72.154

# 境外（如菲律宾）本地采集：每批 1 只、标间/批间加长间隔，降低东方财富断连概率
INGEST_OHLCV_BATCH_SIZE=1
INGEST_OHLCV_BATCH_PAUSE_SEC=30
INGEST_OHLCV_DELAY_BETWEEN_SYMBOLS=8
INGEST_EXTRA_DELAY_SEC=5
# 按阶段分开执行：先全部 K 线 → 停顿 → 全部行业 → 停顿 → 全部新闻（阶段间长停顿或可缓解限流）
INGEST_SEPARATE_PHASES=1
INGEST_PHASE_PAUSE_SEC=120
# 若有境内 HTTP 代理可设（东方财富境外 IP 易被拒时）：INGEST_HTTP_PROXY=http://代理:端口  INGEST_HTTPS_PROXY=...
# ---------- 生产采集开关与时间线（make ingest-production，符合 AB 模块生产要求）----------
# 开关：true/false（或 1/0）。指定 DITING_SYMBOLS 时建议 false，不刷新全 A 股，避免境外首请求断连
INGEST_PRODUCTION_UNIVERSE=false
# K 线/量化（OHLCV 写入 L1，Module B 用）
INGEST_PRODUCTION_OHLCV=true
# 行业/财务（财务摘要写入 L2，Module A 用）
INGEST_PRODUCTION_INDUSTRY_REVENUE=true
# 新闻（全市场 + 按标个股新闻写入 L2，Module C 用）
INGEST_PRODUCTION_NEWS=true
# 时间范围（仅当未配置下方 INGEST_JQDATA_DATE_* 时生效）：K 线回溯天数、新闻保留最近 N 天
# INGEST_PRODUCTION_OHLCV_DAYS_BACK=1825
# INGEST_PRODUCTION_NEWS_DAYS_BACK=365
# ---------- 数据源：JQData（聚宽）----------
JQDATA_USER=13031539952
JQDATA_PASSWORD=Hui123123
# 统一拉取时间范围（格式 YYYY-MM-DD）：配置后 K 线、新闻均按此区间拉取；未配置时用上方 DAYS_BACK
INGEST_JQDATA_DATE_START=2026-01-01
INGEST_JQDATA_DATE_END=2026-03-07

# 数据源：akshare（东方财富）或 jqdata（聚宽）。当前用 akshare
INGEST_SOURCE=AkShare

# 指定股票（默认一套，采集与 Module A/B 共用）：文件路径（每行一个代码）或逗号分隔；未设置则全量
DITING_SYMBOLS=config/diting_symbols.txt