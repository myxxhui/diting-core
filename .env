# ============================================================
# 生产环境连接信息（从 diting-infra/prod.conn 同步；勿提交 Git）
# 来源: make deploy diting prod @ diting-infra
# ============================================================
TIMESCALE_DSN=postgresql://postgres:postgres@8.210.78.39:30001/postgres
PG_L2_DSN=postgresql://postgres:postgres@8.210.78.39:30002/diting_l2
REDIS_URL=redis://8.210.78.39:30379/0
KUBECONFIG=/Users/huishaoqi/.kube/config-diting-prod
PUBLIC_IP=8.210.78.39

# ============================================================
# 标的名单
# ============================================================
# 指定股票（采集与 Module A/B 共用）：文件路径（每行一个代码）或逗号分隔；未设置则全量 A 股
DITING_SYMBOLS=config/diting_symbols.txt

# ============================================================
# 数据源
# ============================================================
INGEST_SOURCE=AkShare
JQDATA_USER=13031539952
JQDATA_PASSWORD=Hui123123

# ============================================================
# 采集模式（核心参数）
# ============================================================
# auto  = 智能增量（默认）：自动检测各维度缺失/过期数据，只补差量
# full  = 强制全量：忽略已有数据，全部重新拉取（首次建库 or 数据修复用）
INGEST_MODE=auto

# ============================================================
# 各维度开关（true/false）
# ============================================================
INGEST_PRODUCTION_UNIVERSE=false
INGEST_PRODUCTION_OHLCV=true
INGEST_PRODUCTION_INDUSTRY_REVENUE=true
INGEST_PRODUCTION_FINANCIAL=true
INGEST_PRODUCTION_NEWS=true

# ============================================================
# 增量策略参数（INGEST_MODE=auto 时生效）
# ============================================================
# K线：DB 中最新日期距今超过此天数才补拉，默认 1（昨天没拉就补）
INGEST_OHLCV_STALE_DAYS=1
# K线：增量拉取时，从 DB 最新日期往前多回溯几天（防数据修正遗漏），默认 3
INGEST_OHLCV_OVERLAP_DAYS=3
# 行业分类：updated_at 超过此天数视为过期，重新拉取，默认 30
INGEST_INDUSTRY_REFRESH_DAYS=30
# 财务报表：updated_at 超过此天数视为过期（季报/年报发布周期），默认 7
INGEST_FINANCIAL_REFRESH_DAYS=7
# 新闻：始终拉取最新（去重入库），true = 每次都拉，false = 有数据就跳过
INGEST_NEWS_ALWAYS_REFRESH=true

# ============================================================
# 全量模式时间范围（INGEST_MODE=full 时生效）
# ============================================================
# K线回溯天数（约 5 年），默认 1825
INGEST_PRODUCTION_OHLCV_DAYS_BACK=1825
# 新闻保留最近 N 天，默认 365
INGEST_PRODUCTION_NEWS_DAYS_BACK=365

# ============================================================
# 限流 / 批间策略
# ============================================================
# 按阶段分开：Phase1 K线 → Phase2 行业 → Phase2.5 财务 → Phase3 新闻
INGEST_SEPARATE_PHASES=1
# 每批标的数
INGEST_OHLCV_BATCH_SIZE=5
# 批间暂停秒
INGEST_OHLCV_BATCH_PAUSE_SEC=10
# 标的间延迟秒
INGEST_EXTRA_DELAY_SEC=3
# 阶段间暂停秒
INGEST_PHASE_PAUSE_SEC=5