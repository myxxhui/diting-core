# 生产环境连接信息（自动生成；勿提交 Git）
# 来源: make deploy diting prod @ diting-infra
# 云服务器跑 AkShare/东方财富 易 RemoteDisconnected 时，可适当减小批次、加大间隔（按需取消注释）：
INGEST_OHLCV_BATCH_SIZE=1
INGEST_OHLCV_BATCH_PAUSE_SEC=5
INGEST_OHLCV_DELAY_BETWEEN_SYMBOLS=5
TIMESCALE_DSN=postgresql://postgres:postgres@43.99.38.67:30001/postgres
PG_L2_DSN=postgresql://postgres:postgres@43.99.38.67:30002/diting_l2
REDIS_URL=redis://43.99.38.67:30379/0
KUBECONFIG=/root/.kube/config-diting-prod
PUBLIC_IP=43.99.38.67
# ---------- 生产采集开关与时间线（make ingest-production，符合 AB 模块生产要求）----------
# 未设置时默认 1（开启）。设为 0 可单独关闭某一类数据拉取。
# 标的池（全 A 股列表，写入 a_share_universe）
INGEST_PRODUCTION_UNIVERSE=1
# K 线/量化（OHLCV 写入 L1，Module B 用）
INGEST_PRODUCTION_OHLCV=1
# 行业/财务（财务摘要写入 L2，Module A 用）
INGEST_PRODUCTION_INDUSTRY_REVENUE=1
# 新闻（全市场 + 按标个股新闻写入 L2，Module C 用）
INGEST_PRODUCTION_NEWS=1
# K 线拉取时间线：回溯天数（仅 AkShare/Baostock 时生效；JQData 用下面日期范围）
# INGEST_PRODUCTION_OHLCV_DAYS_BACK=1825
# ---------- 数据源：JQData（聚宽）----------
# 使用 JQData 时设 INGEST_SOURCE=jqdata，标的/行情/行业财务均从聚宽拉取；需聚宽账号并 pip install jqdatasdk
INGEST_SOURCE=jqdata
JQDATA_USER=13031539952
JQDATA_PASSWORD=Hui123123
# JQData 拉取日期范围（格式 YYYY-MM-DD）；试用版通常为「约 3 个月前～15 个月前」
INGEST_JQDATA_DATE_START=2025-05-01
INGEST_JQDATA_DATE_END=2025-12-01
