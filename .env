# [Ref: 02_三位一体仓库规约] 本地/联调配置；make ingest-production 仅同步下方「连接相关」变量，其它配置保留
# ---------- 连接相关（与 diting-infra prod.conn 同步，仅此块会被 ingest-production 覆盖更新）----------
TIMESCALE_DSN=postgresql://postgres:postgres@8.210.195.188:30001/postgres
PG_L2_DSN=postgresql://postgres:postgres@8.210.195.188:30002/diting_l2
REDIS_URL=redis://8.210.195.188:30379/0
KUBECONFIG=/root/.kube/config-diting-prod
PUBLIC_IP=8.210.195.188

# ---------- 可选（按需填写，不会被 prod.conn 覆盖）----------
API_KEY=
DB_URL=
# 指定股票（采集与 Module A/B 共用）：文件路径或逗号分隔；未设置则全 A 股
DITING_SYMBOLS=config/diting_symbols.txt

# ---------- 采集加速与限速（make ingest-production / make ingest-production-incremental）----------
# INGEST_OHLCV_SOURCE=akshare
INGEST_OHLCV_BATCH_SIZE=150
INGEST_OHLCV_BATCH_PAUSE_SEC=5
INGEST_OHLCV_DELAY_BETWEEN_SYMBOLS=5

# ---------- 生产采集开关与时间线（make ingest-production）----------
INGEST_PRODUCTION_UNIVERSE=true
INGEST_PRODUCTION_OHLCV=true
INGEST_PRODUCTION_INDUSTRY_REVENUE=true
INGEST_PRODUCTION_NEWS=true
INGEST_PRODUCTION_OHLCV_DAYS_BACK=1825
INGEST_PRODUCTION_NEWS_DAYS_BACK=365

# ---------- 数据源：JQData（聚宽，按需启用）----------
# INGEST_SOURCE=jqdata
# JQDATA_USER=
# JQDATA_PASSWORD=
# INGEST_JQDATA_DATE_START=2025-05-01
# INGEST_JQDATA_DATE_END=2025-12-01
# 可选，默认 45 秒；10～120 有效
INGEST_REQUESTS_TIMEOUT=20